<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.6.xsd">

    <!--
        Replaces beer_order_beers (an @ElementCollection side table that carried only a beer_id
        per row) with beer_order_line, a full child entity carrying quantity and a name/price
        snapshot per line. The dropped table also fixes a latent bug: it had a UNIQUE constraint
        on beer_id alone, meaning a given beer could only ever appear in one order across the
        entire system.
    -->
    <changeSet author="pkormoczi" id="drop_beer_order_beers" logicalFilePath="db/changelog/1.1.0/create-beer-order-line.xml">
        <dropTable tableName="beer_order_beers"/>
    </changeSet>

    <changeSet author="pkormoczi" id="create_beer_order_line" logicalFilePath="db/changelog/1.1.0/create-beer-order-line.xml">
        <createTable tableName="beer_order_line">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_beer_order_line"/>
            </column>
            <column name="order_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="beer_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="beer_name_snapshot" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="unit_price_snapshot_amount" type="NUMERIC(19, 2)">
                <constraints nullable="false"/>
            </column>
            <column name="quantity" type="INT">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet author="pkormoczi" id="fk_beer_order_line_order">
        <addForeignKeyConstraint baseColumnNames="order_id" baseTableName="beer_order_line"
                                 constraintName="fk_beer_order_line_order" deferrable="false"
                                 initiallyDeferred="false" onDelete="CASCADE" onUpdate="NO ACTION"
                                 referencedColumnNames="id" referencedTableName="beer_order" validate="true"/>
    </changeSet>
</databaseChangeLog>
